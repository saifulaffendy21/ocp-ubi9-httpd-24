apiVersion: apps/v1
kind: Deployment
metadata:
  name: httpd
  namespace: web
  labels: { app: httpd }
spec:
  replicas: 2
  revisionHistoryLimit: 5
  strategy:
    type: RollingUpdate
    rollingUpdate: { maxUnavailable: 1, maxSurge: 1 }
  selector:
    matchLabels: { app: httpd }
  template:
    metadata:
      labels: { app: httpd }
    spec:
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile: { type: RuntimeDefault }
      containers:
        - name: httpd
          image: registry.ocp4.example.com:8443/ubi9/httpd-24:latest
          imagePullPolicy: IfNotPresent
          # Do NOT set command/args — use image defaults
          ports:
            - name: http
              containerPort: 8080
          resources:
            requests: { cpu: "200m", memory: "256Mi" }
            limits:   { cpu: "500m", memory: "512Mi" }
          volumeMounts:
            - name: site
              mountPath: /var/www/html
              readOnly: true
          readinessProbe:
            httpGet: { path: "/", port: http }
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: 2
            failureThreshold: 6
          livenessProbe:
            httpGet: { path: "/", port: http }
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 2
            failureThreshold: 3
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            runAsNonRoot: true
            # Let OpenShift assign an arbitrary UID
            capabilities: { drop: ["ALL"] }
      volumes:
        - name: site
          configMap:
            name: httpd-site
            defaultMode: 0444
